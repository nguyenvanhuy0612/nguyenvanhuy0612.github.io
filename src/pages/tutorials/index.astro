---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const tutorials = (await getCollection('tutorials')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Tutorials">
  <div class="section-header">
    <h1>Tutorials</h1>
    <p>Step-by-step tutorials on various topics.</p>
  </div>

  <ul class="post-list">
    {tutorials.map(item => (
      <li>
        <h3><a href={`/tutorials/${item.id}/`}>{item.data.title}</a></h3>
        <time>{item.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        {item.data.description && <p>{item.data.description}</p>}
      </li>
    ))}
  </ul>
</Base>
