---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 5);
const tutorials = (await getCollection('tutorials')).slice(0, 3);
const guides = (await getCollection('guides')).slice(0, 3);
---
<Base>
  <h1>Welcome</h1>
  <p>A personal collection of tutorials, guides, and notes.</p>

  {posts.length > 0 && (
    <>
      <h2>Recent Posts</h2>
      <ul class="post-list">
        {posts.map(post => (
          <li>
            <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
            <time>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            {post.data.description && <p>{post.data.description}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {tutorials.length > 0 && (
    <>
      <h2>Tutorials</h2>
      <ul class="post-list">
        {tutorials.map(item => (
          <li>
            <h3><a href={`/tutorials/${item.id}/`}>{item.data.title}</a></h3>
            {item.data.description && <p>{item.data.description}</p>}
          </li>
        ))}
      </ul>
    </>
  )}

  {guides.length > 0 && (
    <>
      <h2>Guides</h2>
      <ul class="post-list">
        {guides.map(item => (
          <li>
            <h3><a href={`/guides/${item.id}/`}>{item.data.title}</a></h3>
            {item.data.description && <p>{item.data.description}</p>}
          </li>
        ))}
      </ul>
    </>
  )}
</Base>
