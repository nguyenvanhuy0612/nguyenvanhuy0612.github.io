---
import Base from './Base.astro';

interface Props {
  title: string;
  date?: Date;
  tags?: string[];
}

const { title, date, tags } = Astro.props;
---
<Base title={title}>
  <article class="post">
    <header>
      <h1>{title}</h1>
      {date && <time>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
      {tags && tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>
    <div class="content">
      <slot />
    </div>
  </article>
</Base>
